{
  "name": "traceforge",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first black box recorder for artificial intelligence agent runs.",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "corepack pnpm -r --if-present build",
    "test": "vitest run",
    "check": "corepack pnpm -r --if-present check",
    "verify": "corepack pnpm build && corepack pnpm test",
    "traceforge": "corepack pnpm --filter @traceforge/cli traceforge"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
